{
  "permissions": {
    "allow": [
      // Common entries to add per project:
      // "Bash(npm run lint:*)",
      // "Bash(npm run test:*)",
      // "Bash(npx drizzle-kit:*)",
      // "Bash(git log:*)",
      // "Bash(git diff:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_ROOT/hooks/block-impl-import-in-presentation.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_ROOT/hooks/lint-on-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "PROJECT_ROOT/hooks/check-use-server.sh"
          }
        ]
      }
    ]
  }
}
